#!/usr/bin/env bash
# next-release — bump patch version, commit, and tag for the current release branch.
#
# Usage:
#   scripts/next-release          # auto-detects next patch from existing tags
#
# What it does:
#   1. Verifies the current branch matches v<major>.<minor> (e.g. v0.1)
#   2. Finds the highest existing v<major>.<minor>.* tag
#   3. Increments the patch number (or starts at .0 if no tag exists yet)
#   4. Updates version = "..." in pyproject.toml
#   5. Commits with "chore: release <tag>"
#   6. Creates the annotated git tag
#
# After running, push with:
#   git push origin <branch> --tags
# The release.yml workflow then creates the GitHub Release and updates the
# floating minor tag so users on `pip install --upgrade "...@v0.1"` are covered.

set -euo pipefail

# ── 1. Verify we are on a release branch ──────────────────────────────────────

BRANCH=$(git rev-parse --abbrev-ref HEAD)

if ! echo "$BRANCH" | grep -qP '^v\d+\.\d+$'; then
  echo "error: must be on a release branch like 'v0.1', current branch is '$BRANCH'" >&2
  exit 1
fi

MAJOR_MINOR="${BRANCH#v}"   # e.g. 0.1

# ── 2. Find the highest existing patch tag ────────────────────────────────────

LATEST=$(git tag --list "v${MAJOR_MINOR}.*" | sort -V | tail -1)

if [ -z "$LATEST" ]; then
  NEXT_PATCH=0
else
  NEXT_PATCH=$(( ${LATEST##*.} + 1 ))
fi

NEXT_TAG="v${MAJOR_MINOR}.${NEXT_PATCH}"
NEXT_VERSION="${MAJOR_MINOR}.${NEXT_PATCH}"

# ── 3. Guard: tag must not already exist ─────────────────────────────────────

if git tag --list "$NEXT_TAG" | grep -q .; then
  echo "error: tag $NEXT_TAG already exists" >&2
  exit 1
fi

echo "Branch : $BRANCH"
echo "Latest : ${LATEST:-"(none)"}"
echo "Next   : $NEXT_TAG  (version $NEXT_VERSION)"
echo ""

# ── 4. Update pyproject.toml ─────────────────────────────────────────────────

PYPROJECT="pyproject.toml"

if [ ! -f "$PYPROJECT" ]; then
  echo "error: $PYPROJECT not found" >&2
  exit 1
fi

# Replace the version line; fail if the pattern is not found
if ! grep -q '^version = "' "$PYPROJECT"; then
  echo "error: could not find 'version = \"...\"' in $PYPROJECT" >&2
  exit 1
fi

sed -i "s/^version = \".*\"/version = \"${NEXT_VERSION}\"/" "$PYPROJECT"
echo "Updated $PYPROJECT → version = \"$NEXT_VERSION\""

# ── 5. Commit ─────────────────────────────────────────────────────────────────

git add "$PYPROJECT"
git commit -m "chore: release ${NEXT_TAG}"

# ── 6. Tag ────────────────────────────────────────────────────────────────────

git tag -a "$NEXT_TAG" -m "Release ${NEXT_TAG}"
echo "Tagged  $NEXT_TAG"

# ── 7. Next steps ─────────────────────────────────────────────────────────────

echo ""
echo "Done. Push with:"
echo "  git push origin ${BRANCH} --tags"
